{
  "name": "stamp-monitor",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Solar-Punk-Ltd/stamp-monitor.git"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "bundle": "rimraf bundle && esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=bundle/index.js && cp -r stamps bundle/stamps && cp .env bundle/.env",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "start": "ts-node src/index.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "resend": "^6.9.3",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.55.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^2.8.8",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
